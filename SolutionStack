import java.util.Arrays;
import java.util.List;

class Solution {
    public List<String> buildArray(int[] target, int n) { 
        String[] temp = new String[n * 2]; 
        int index = 0;
        int currentStreamNum = 1;
        for (int num : target) {
            while (currentStreamNum < num) {
                temp[index++] = "Push";
                temp[index++] = "Pop";
                currentStreamNum++;
            }
            temp[index++] = "Push";
            currentStreamNum++;
        }
        String[] resultArr = Arrays.copyOf(temp, index);
        return Arrays.asList(resultArr);
    }
}
